#!/usr/bin/env bash
# openclaw-wrapper — translates Alfred's backend CLI invocation to OpenClaw's format.
#
# Alfred calls:  <command> [args...] --workspace <path> <prompt>
# OpenClaw expects: openclaw agent --message "<prompt>" --workspace <path> --json
#
# This wrapper bridges the two conventions.

set -euo pipefail

WORKSPACE=""
PROMPT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --workspace)
            WORKSPACE="$2"
            shift 2
            ;;
        *)
            PROMPT="$1"
            shift
            ;;
    esac
done

ARGS=(agent --message "$PROMPT")
if [[ -n "$WORKSPACE" ]]; then
    ARGS+=(--workspace "$WORKSPACE")
fi
ARGS+=(--json)

exec openclaw "${ARGS[@]}" 2>/dev/null
